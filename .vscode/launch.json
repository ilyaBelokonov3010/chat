{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Flask Chat Debugger",
            "type": "debugpy",
            "request": "launch",
            "module": "flask",
            "env": {
                "FLASK_APP": "main.py",
                "FLASK_DEBUG": "1"
            },
            "args": [
                "run",
                "--no-reload",
                "--no-debugger",
                "--port", "5000"
            ],
            "jinja": true,
            "justMyCode": true
        }
    ]
}
